GEMINI_API_KEY=your_gemini_api_key_here
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key (Supabase Dashboard → Settings → API). NEVER expose to the
# client — only used server-side by the RevenueCat webhook to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Shared secret configured as the "Authorization header value" in the
# RevenueCat dashboard webhook settings. Any long random string.
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret_here

# Comma-separated list of allowed origins for CORS. Defaults to "*" (open) if
# unset — fine for a mobile-only client, but set explicitly for production.
ALLOWED_ORIGINS=
